{
  "name": "taowry",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "homepage": "https://github.com/feitingjun/taowry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feitingjun/taowry"
  },
  "scripts": {
    "build:ts": "tsc --outDir dist",
    "build:dev": "napi build --platform --release && mv index.darwin-arm64.node taowry.node",
    "build:all": "./build.sh"
  },
  "author": "",
  "license": "ISC",
  "description": "基于 tao + wry 的跨平台 WebView 窗口库，支持 Node.js 和 Bun",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
