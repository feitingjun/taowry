{
  "name": "taowry",
  "version": "0.1.0",
  "main": "dist/src/ts/index.js",
  "types": "dist/src/ts/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/ts/index.d.ts",
      "default": "./dist/src/ts/index.js"
    },
    "./client": {
      "types": "./dist/src/ts/client.d.ts",
      "default": "./dist/src/ts/client.js"
    }
  },
  "homepage": "https://github.com/feitingjun/taowry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feitingjun/taowry"
  },
  "scripts": {
    "start": "bun ./test/index.ts",
    "build": "napi build --platform --release && tsc",
    "build:all": "./build.sh"
  },
  "author": "",
  "license": "ISC",
  "description": "基于 tao + wry 的跨平台 WebView 窗口库，支持 Node.js 和 Bun",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
