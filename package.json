{
  "name": "taowry",
  "version": "0.0.4",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "homepage": "https://github.com/feitingjun/taowry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feitingjun/taowry.git"
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "build:dev": "napi build --platform --release && mv index.darwin-arm64.node src/taowry.node",
    "build:all": "./build.sh",
    "test": "bun test src/ts/__tests__/",
    "test:rust": "cargo test",
    "test:all": "cargo test && bun test src/ts/__tests__/",
    "postinstall": "node ./scripts/postinstall.cjs"
  },
  "author": "",
  "license": "ISC",
  "description": "基于 tao + wry 的跨平台 WebView 窗口库，支持 Node.js 和 Bun",
  "devDependencies": {
    "@napi-rs/cli": "^3.7.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
