{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "allowJs": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "allowArbitraryExtensions": true,
    "rootDir": "src/ts",
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "types": [
      "bun"
    ]
  },
  "include": [
    "src/ts/**/*.ts",
  ]
}